# Server
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Database (Phase 1)
# DATABASE_URL=postgresql://syncwire:syncwire@postgres:5432/syncwire

# JWT (Phase 1) — generate a strong secret, e.g. openssl rand -hex 32
# JWT_SECRET=
# JWT_SECRET_PREVIOUS=
# JWT_ACCESS_TTL_SECONDS=3600
# JWT_REFRESH_TTL_SECONDS=7776000

# EMQX broker (Phase 2)
# EMQX_URL=mqtt://emqx:1883
# EMQX_BRIDGE_USERNAME=bridge
# EMQX_BRIDGE_PASSWORD=

# Storage / retention
NOTIFICATION_RETENTION_DAYS=30
